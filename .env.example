# ----------------------------------------------------------------------
# Project Environment Configuration
# Auto-generated by initialize.sh
# ----------------------------------------------------------------------

# ======================================================================
# 1. BUILD STRATEGY (Multi-Stage Docker)
# ======================================================================
# Controls which stage of the Dockerfile is built.
#
# Options:
#   dev  -> Installs Gazebo, RViz, GDB, and GUI tools. (Best for PC/Laptop)
#   prod -> Minimal runtime only. No simulators. (Best for Robot/Deployment)
#
BUILD_TARGET=dev


# ======================================================================
# 2. GRAPHICS & NETWORK CONFIGURATION
# ======================================================================
# Uncomment the block below that matches your operating system.

# 🐧 LINUX NATIVE CONFIGURATION:
# Use this if you are running Ubuntu/Debian natively.
# DISPLAY_CONFIG=\${DISPLAY}
# NETWORK_MODE_CONFIG=host

# 🍎 WINDOWS / 🍏 MACOS (DOCKER DESKTOP):
# Use this if you are using Docker Desktop.
# Requires an XServer (VcXsrv/XQuartz) installed on host.
#DISPLAY_CONFIG=host.docker.internal:0
#NETWORK_MODE_CONFIG=bridge

# ----------------------------------------------------------------------
# ⚠️  DEFAULT FALLBACK (If you don't uncomment anything above)
# ----------------------------------------------------------------------
# If you leave everything commented, these defaults usually work for 
# Windows/Mac users, but Linux users will lose GUI access.
DISPLAY_CONFIG=host.docker.internal:0
NETWORK_MODE_CONFIG=bridge


# ======================================================================
# 3. ONSHAPE API CREDENTIALS (for URDF/STL export)
# ======================================================================
# Used by scripts/export_urdf.sh inside the container.
# Generate keys at: https://dev-portal.onshape.com/keys
ONSHAPE_API=https://cad.onshape.com
ONSHAPE_ACCESS_KEY=???
ONSHAPE_SECRET_KEY=???

# ─────────────────────────────────────────────────────────────────────────────
# Camera profile — switch between robot hardware and laptop webcam for dev/debug.
#
# Profiles:
#   rpicam  →  RPi CSI camera via TCP stream from rpicam-vid (robot container)
#   webcam  →  USB/laptop webcam via OpenCV (local dev/debug)
#
# Usage:
#   1. Copy this file to .env  (scripts/initialize-env.sh does this for you)
#   2. Set CAMERA_PROFILE to 'rpicam' or 'webcam'
#   3. Run:  ./scripts/launch_vision.sh
#      (sources .env automatically before calling ros2 launch)
# ─────────────────────────────────────────────────────────────────────────────

# Active profile: rpicam | webcam
CAMERA_PROFILE=rpicam

# ── rpicam profile defaults ───────────────────────────────────────────────────
# TCP stream produced by rpicam-vid on the Pi host (outside Docker).
# Enable the stream service on the Pi:
#   sudo systemctl enable --now rpicam-stream
# Then inside the Docker container the host is reachable at 127.0.0.1 (host networking).
RPICAM_TCP_HOST=127.0.0.1
RPICAM_TCP_PORT=8554

# ── webcam profile defaults ───────────────────────────────────────────────────
# V4L2 device index for your laptop/USB webcam (/dev/video<N>).
# Find yours with:  v4l2-ctl --list-devices  or  ls /dev/video*
WEBCAM_DEVICE_ID=0

# ── shared / override settings ────────────────────────────────────────────────
# These apply to both profiles. Leave blank to use profile defaults above.
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30.0

# Force a specific backend regardless of profile (leave blank to use profile default):
#   auto | picamera2 | tcp | opencv
CAMERA_BACKEND=
